#!/usr/bin/env zsh

# Use the active virtualenv's pip if there is one. Otherwise, refuse -
#  Homebrew's Python is externally managed and won't allow a bare
#  `pip install` outside a venv anyway. Use uv instead.

if [[ -n $VIRTUAL_ENV ]]; then
  $VIRTUAL_ENV/bin/pip "$@"
else
  echo "Not in a virtualenv - pip won't work here (Homebrew's Python is externally managed)."
  echo "Use uv instead:"
  echo "  uv tool install <package>          # standalone CLI tool"
  echo "  uv venv && uv pip install <package> # project/library dependency"
  exit 1
fi
