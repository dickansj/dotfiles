#!/usr/bin/env bash

# cleans up the turds left behind by the Finder on external drives
#   (useful for plugging media drives into TVs which don't know
#    what do to with said files)

BASEDIR="/Volumes/"
SKIPS=("Time Machine" "Macintosh HD" "com.apple.TimeMachine.localsnapshots")

# exact-match against the skip list; the old substring-in-"${SKIPS[@]}"
#   regex trick concatenated the array, so one entry being a prefix of a
#   volume name could false-positive
should_skip() {
    local name=$1 s
    for s in "${SKIPS[@]}"; do
        if [[ $s == "$name" ]]; then
            return 0
        fi
    done
    return 1
}

VOLS=()
for v in "$BASEDIR"*; do
    if ! should_skip "${v:${#BASEDIR}}"; then
        VOLS+=("${v:${#BASEDIR}}")
    fi
done

echo "Choose a drive to clean up:"
select vol in "${VOLS[@]}"
do
    volpath=$BASEDIR$vol
    echo $volpath
    pushd $volpath
        dot_clean -m $volpath
        find . -name '*.DS_Store' -type f -delete
        find . -name '.Trashes' -type d -delete
    popd
    exit
done

