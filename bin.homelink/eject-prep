#!/usr/bin/env bash

# Clears out processes that hold external volumes open, so a following
#   eject doesn't fail with "disk in use".
#
# Actual ejecting is handled by Mountio (https://mountio.app), which has no
#   scripting/automation API of its own - paired with it via a Keyboard
#   Maestro macro (not tracked here; KM keeps macros in its own library, not
#   files) bound to Shift+Option+Cmd+E:
#     1. Execute Shell Script: ~/bin/eject-prep
#     2. Execute AppleScript, targeting Mountio's status item by
#        accessibility role rather than screen pixels (image matching broke
#        under badge-count/Retina/light-dark changes):
#          tell application "System Events"
#              tell process "Mountio"
#                  click menu bar item 1 of menu bar 1
#                  delay 0.3
#                  click menu item "Unmount all" of menu 1 of menu bar item 1 of menu bar 1
#              end tell
#          end tell
#        Needs Accessibility access (System Settings > Privacy & Security >
#        Accessibility) granted to "Keyboard Maestro Engine" specifically -
#        the background process that runs macros, not the editor app.

# tell Backblaze to chill for a second
# /Applications/Backblaze.app/Contents/MacOS/bzcli action --pause-backup

# the Finder's thumbnail creation process sometimes holds on to files too long
## annoying as heck when trying to eject!
## cf. https://github.com/Marginal/QuickLookVideo/issues/188
killall -v -q -9 QLVideo\ Codecs
killall -v -q -9 QLVideo\ Formats
killall -v -q -9 AudiovisualThumbnailExtension

# if there was nothing to kill at the last command it will not exit clean
## we don't really care; this is just about clearing out whatever exists
exit 0
